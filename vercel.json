{
  "buildCommand": "npm run data && npm run og && npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/name", "destination": "/", "permanent": false }
  ],
  "rewrites": [
    { "source": "/name/:slug", "destination": "/name/lookup" }
  ]
}
