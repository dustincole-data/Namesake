{
  "buildCommand": "npm run data && npm run og && npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/og.ts": {
      "includeFiles": "{scripts/card.ts,src/lib/archetype.ts,src/lib/reveal.ts,src/lib/format.ts,src/lib/chart.ts}"
    }
  },
  "redirects": [
    { "source": "/name", "destination": "/", "permanent": false }
  ],
  "rewrites": [
    { "source": "/name/:slug", "destination": "/name/lookup" }
  ]
}
